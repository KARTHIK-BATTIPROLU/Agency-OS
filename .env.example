# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: MongoDB Atlas connection string — the only database. Clients,
# packages, activities, activity files, users, tasks, and invoices all live here.
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=Cluster0"
# MONGODB_DB: Database name to use inside the cluster.
MONGODB_DB="agency_os"

# FIREBASE_AUTH_PROJECT_ID: Firebase project used ONLY for login (email/password)
# — no Firestore/database usage, no Storage usage; uploaded files live in
# MongoDB GridFS instead.
FIREBASE_AUTH_PROJECT_ID="agency-os-sla-72519"

# FIREBASE_SERVICE_ACCOUNT: base64-encoded service account JSON for the
# agency-os-sla-72519 project. Required when running off Google Cloud (e.g.
# Render) so firebase-admin can authenticate Auth tokens.
# Generate with: base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT=""

# FRONTEND_ORIGINS: comma-separated list of browser origins allowed to call this API
# directly (CORS). Never set to "*" in production.
FRONTEND_ORIGINS="https://your-frontend.netlify.app"

# VITE_API_URL: absolute URL of the deployed backend, read by the frontend build.
# Leave blank for local dev (same-origin via the Vite-in-Express dev server).
VITE_API_URL=""
