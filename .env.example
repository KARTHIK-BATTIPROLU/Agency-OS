# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: MongoDB Atlas connection string for the users/data store.
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=Cluster0"
# MONGODB_DB: Database name to use inside the cluster.
MONGODB_DB="agency_os"

# FIREBASE_AUTH_PROJECT_ID: Firebase project that issues auth tokens (email/password).
FIREBASE_AUTH_PROJECT_ID="agency-os-sla-72519"

# FIREBASE_STORAGE_BUCKET: bucket used for uploaded activity files (replaces local disk uploads).
# Must match the SAME project as FIREBASE_SERVICE_ACCOUNT below (the Firestore data
# project, gen-lang-client-0563145298) — not FIREBASE_AUTH_PROJECT_ID above.
FIREBASE_STORAGE_BUCKET="gen-lang-client-0563145298.firebasestorage.app"

# FIREBASE_SERVICE_ACCOUNT: base64-encoded service account JSON for the
# gen-lang-client-0563145298 project (the Firestore data project, per
# firebase-applet-config.json). Required when running off Google Cloud (e.g.
# Render) so firebase-admin can authenticate to Firestore/Storage/Auth.
# Generate with: base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT=""

# FRONTEND_ORIGINS: comma-separated list of browser origins allowed to call this API
# directly (CORS). Never set to "*" in production.
FRONTEND_ORIGINS="https://your-frontend.netlify.app"

# VITE_API_URL: absolute URL of the deployed backend, read by the frontend build.
# Leave blank for local dev (same-origin via the Vite-in-Express dev server).
VITE_API_URL=""
