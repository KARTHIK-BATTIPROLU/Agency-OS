{
  "entities": {
    "User": {
      "title": "User",
      "description": "An agency staff member or administrator",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User identifier" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "description": "Email address" },
        "role": { "type": "string", "enum": ["Admin", "Manager"], "description": "Agency operations role" },
        "is_deleted": { "type": "boolean", "description": "Soft delete status" },
        "deleted_at": { "type": "string", "description": "ISO timestamp for deletion" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "A client organization managed by the agency",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Client identifier" },
        "client_name": { "type": "string", "description": "Name of the client entity" },
        "logo": { "type": "string", "description": "Logo character/abbreviation or image URL/path" },
        "industry": { "type": "string", "description": "Industry vertical" },
        "start_date": { "type": "string", "description": "Partnership start date" },
        "status": { "type": "string", "enum": ["Active", "Paused"], "description": "Current status" },
        "is_deleted": { "type": "boolean", "description": "Soft delete status flag" },
        "deleted_at": { "type": "string", "description": "ISO timestamp of deletion" },
        "created_at": { "type": "string", "description": "ISO timestamp of creation" }
      },
      "required": ["id", "client_name", "logo", "industry", "start_date", "status"]
    },
    "MonthlyPackage": {
      "title": "MonthlyPackage",
      "description": "SLA targets for a client for a specific month and year",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Package target identifier" },
        "client_id": { "type": "string", "description": "Referenced client ID" },
        "month": { "type": "integer", "description": "Month number (1-12)" },
        "year": { "type": "integer", "description": "Year (e.g., 2026)" },
        "posters_target": { "type": "integer" },
        "reels_target": { "type": "integer" },
        "video_editing_target": { "type": "integer" },
        "ad_campaigns_target": { "type": "integer" },
        "blogs_target": { "type": "integer" },
        "content_writing_target": { "type": "integer" },
        "script_writing_target": { "type": "integer" },
        "website_updates_target": { "type": "integer" },
        "is_deleted": { "type": "boolean" },
        "deleted_at": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "client_id", "month", "year"]
    },
    "Activity": {
      "title": "Activity",
      "description": "An action or artifact logged under a client's SLA",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "activity_id_code": { "type": "string", "description": "Auto generated ID, e.g., ACT-2026-0001" },
        "client_id": { "type": "string" },
        "activity_type": { "type": "string" },
        "sub_type": { "type": "string" },
        "stage": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "activity_date": { "type": "string" },
        "drive_link": { "type": "string" },
        "notes": { "type": "string" },
        "is_deleted": { "type": "boolean" },
        "deleted_at": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "activity_id_code", "client_id", "activity_type", "stage", "title", "activity_date"]
    },
    "ActivityFile": {
      "title": "ActivityFile",
      "description": "An attachment associated with an activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "activity_id": { "type": "string" },
        "file_name": { "type": "string" },
        "file_path": { "type": "string" },
        "file_type": { "type": "string" },
        "uploaded_at": { "type": "string" }
      },
      "required": ["id", "activity_id", "file_name", "file_path", "file_type", "uploaded_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Database of registered team members"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Database of clients"
    },
    "/monthly_packages/{packageId}": {
      "schema": "MonthlyPackage",
      "description": "SLA target configurations"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Database of activity deliverables"
    },
    "/activity_files/{fileId}": {
      "schema": "ActivityFile",
      "description": "Database of file attachments on activities"
    }
  }
}
